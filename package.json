    "@types/react": "^19.2.14",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "react-devtools-core": "^7.0.1",
    "tsup": "^8",
    "tsx": "^4"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.87.0",
    "@clack/prompts": "^1.0.1",
    "@google/generative-ai": "^0.24.1",
